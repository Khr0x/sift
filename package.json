{
  "name": "sift",
  "version": "1.0.0",
  "description": "Secure Information Filtering Tool",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "test:integration": "vitest run integration.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://Khr0x@github.com/Khr0x/sift.git"
  },
  "keywords": [
    "logging",
    "logger",
    "security",
    "obfuscation",
    "obfuscator",
    "redaction",
    "redacter",
    "middleware",
    "tracing",
    "distributed-tracing",
    "sensitive-data",
    "data-masking",
    "pii",
    "gdpr",
    "nestjs",
    "express"
  ],
  "author": "khr0x",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Khr0x/sift/issues"
  },
  "homepage": "https://github.com/Khr0x/sift#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "crypto": "^1.0.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
